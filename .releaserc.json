{
  "branches": [
    "main"
  ],
  "tagFormat": "v${version}",
  "plugins": [
    [
      "@semantic-release/commit-analyzer",
      {
        "preset": "conventionalcommits"
      }
    ],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "flutter build apk --release --build-name ${nextRelease.version} --build-number ${process.env.GITHUB_RUN_NUMBER} && mkdir -p build/releases && cp build/app/outputs/flutter-apk/app-release.apk build/releases/open-car-app-v${nextRelease.version}.apk"
      }
    ],
    [
      "@semantic-release/release-notes-generator",
      {
        "preset": "conventionalcommits"
      }
    ],
    [
      "@semantic-release/github",
      {
        "assets": [
          {
            "path": "build/releases/open-car-app-v${nextRelease.version}.apk",
            "label": "Android APK"
          }
        ],
        "successComment": false,
        "failComment": false,
        "releasedLabels": false
      }
    ]
  ]
}